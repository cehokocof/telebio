# ─── Telegram credentials ───────────────────────────────
# Get yours at https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Optional: Bot token for management bot (get from @BotFather)
# Leave empty to disable bot management
BOT_TOKEN=123

# ─── Bio provider ───────────────────────────────────────
# "list" — pick from data/phrases.json (sequential)
# "llm"  — generate via YandexGPT prompt + examples
# "context" — generate via YandexGPT from recent outgoing messages
BIO_PROVIDER=list

# ─── Schedule ───────────────────────────────────────────
# How often to change bios (in minutes)
UPDATE_INTERVAL_MINUTES=60

# ─── YandexGPT (required when BIO_PROVIDER=llm/context) ─
# API key from https://console.yandex.cloud/
YANDEX_API_KEY=your_yandex_api_key_here
# Folder ID from Yandex Cloud console
YANDEX_FOLDER_ID=your_folder_id_here
# Model: yandexgpt-lite/latest, yandexgpt/latest, etc.
YANDEX_MODEL=yandexgpt-lite/latest
# Temperature 0.0–1.0 (higher = more creative)
YANDEX_TEMPERATURE=0.9

# ─── Context mode defaults (bot can change and persist them) ─
# Recent outgoing messages window: last N days and max N messages
CONTEXT_DAYS=14
CONTEXT_LIMIT=500
CONTEXT_DIALOG_SCAN_LIMIT=10
CONTEXT_PER_DIALOG_LIMIT=50
CONTEXT_TOP_K=15
CONTEXT_MIN_SCORE=0.55
CONTEXT_EXCLUDED_DIALOGS=telebio
CONTEXT_ENABLE_NLI=true
CONTEXT_SEMANTIC_SCORER=nli
CONTEXT_NLI_MODEL=cointegrated/rubert-base-cased-nli-threeway
CONTEXT_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Runtime state file for bot-controlled mode/context settings
STATE_FILE=telebio_state.json

# ─── Paths ──────────────────────────────────────────────
# Telethon session file name (without .session extension)
SESSION_NAME=telebio
# JSON file with phrases (relative to project root)
PHRASES_FILE=data/phrases.json
# JSON file with few-shot examples for LLM
EXAMPLES_FILE=data/examples.json

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL=INFO
