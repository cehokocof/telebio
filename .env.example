# ─── Telegram credentials ──────────────────────────────────────────────────
# Обязательные. Получаются один раз на https://my.telegram.org/apps.
# Используются Telethon-клиентом для MTProto-логина и для всех вызовов
# (update_bio, выборка outgoing-сообщений и т.д.).
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Токен управляющего бота от @BotFather. Если пусто — бот не поднимается,
# работает только фоновый scheduler. Команды бота доступны только владельцу
# аккаунта (по user_id из текущей Telethon-сессии).
BOT_TOKEN=

# ─── Schedule ──────────────────────────────────────────────────────────────
# Период тика scheduler-а. Каждый тик: попытка взять bio у провайдера и вызов
# Telethon update_bio. Для telegram_context тик может закончиться NoOp, если батч
# ещё не собран (см. TELEGRAM_CONTEXT_MIN_BATCH).
UPDATE_INTERVAL_MINUTES=60

# ─── Logging ───────────────────────────────────────────────────────────────
# Уровень корневого логгера. DEBUG включает много шумных строк от Telethon.
LOG_LEVEL=INFO

# ─── Paths ─────────────────────────────────────────────────────────────────
# Имя Telethon-сессии (без .session). При первом запуске создаётся файл
# <SESSION_NAME>.session с авторизацией; терять его = логиниться заново.
SESSION_NAME=telebio
# JSON-массив строк для list-провайдера. Фразы > 70 символов обрезаются.
PHRASES_FILE=data/phrases.json
# JSON-массив few-shot-примеров для llm_prompt_generation (включаются в prompt
# как пары user → assistant). На telegram_context не влияет.
EXAMPLES_FILE=data/examples.json
# JSON-массив именованных промптов [{"name","system"}] для llm_prompt_generation.
# Бот умеет их перечислять, показывать текст и переключать активный.
PROMPTS_FILE=data/prompts.json

# ─── YandexGPT ─────────────────────────────────────────────────────────────
# API-ключ Yandex Cloud Foundation Models. Нужен для llm_prompt_generation и telegram_context.
YANDEX_API_KEY=
# Folder ID в Yandex Cloud, в котором выписан ключ.
YANDEX_FOLDER_ID=
# Имя модели в URI: yandexgpt-lite/latest, yandexgpt/latest, yandexgpt-32k/rc и т.д.
# telegram_context рассчитан на полную yandexgpt (lite даёт хуже стиль на batch-prompt).
YANDEX_MODEL=yandexgpt/latest
# Температура генерации. 0.0 — детерминированно, 1.0 — максимальный разброс.
# telegram_context ставит 0.7 (живой стиль, но не разваливается).
YANDEX_TEMPERATURE=0.7

# ─── telegram_context: сбор сообщений ──────────────────────────────────────────
# Период фонового опроса Telegram на новые исходящие сообщения. Отдельный от
# UPDATE_INTERVAL_MINUTES, потому что собирать данные имеет смысл реже, чем
# пытаться сгенерировать bio (на каждой попытке мы только проверяем готовность
# батча — классификация уже сделана офлайн).
TELEGRAM_CONTEXT_POLL_MINUTES=60
# Сколько дней истории перечитывать на каждом опросе. Окно overlap нужно,
# чтобы дотянуть редактированные сообщения; дедупликация — по message_key
# в SQLite.
TELEGRAM_CONTEXT_FETCH_DAYS=7
# Лимиты сканирования: сколько диалогов брать и сколько сообщений из каждого.
# Произведение — верхняя граница messages-per-poll. Маленькие значения
# экономят квоту Telegram и время эмбеддингов.
TELEGRAM_CONTEXT_DIALOG_SCAN_LIMIT=500
TELEGRAM_CONTEXT_PER_DIALOG_LIMIT=100

# ─── telegram_context: склейка соседних сообщений ──────────────────────────────
# Соседние исходящие одного диалога склеиваются в одно «сообщение для
# классификатора», пока не выполнится одно из двух:
#   1) собеседник прислал входящее (естественный конец вашей реплики);
#   2) gap между соседями > merge_gap_seconds (sanity-cap).
# Это делает классификацию устойчивее: фразы вроде «ну», «короче», «короче
# вот» по отдельности — мусор, а вместе — осмысленная реплика. 0 = выкл.
TELEGRAM_CONTEXT_MERGE_GAP_SECONDS=1800

# ─── telegram_context: pre-filter по длине ─────────────────────────────────────
# Сообщения длиннее порога (в символах) помечаются drop ещё до эмбеддингов
# и NLI. Зачем: длинные «портянки» а) едят пиковую память на эмбеддинге
# (вплоть до OOM на CPU-боксе), б) в bio всё равно не пригодны. 0 = выкл.
TELEGRAM_CONTEXT_MAX_MESSAGE_LENGTH=1000

# ─── telegram_context: батчинг ─────────────────────────────────────────────────
# Bio генерится только когда в очереди накопилось не меньше MIN_BATCH
# сообщений с label ∈ {maybe, keep}. Это «нормальный» режим.
TELEGRAM_CONTEXT_MIN_BATCH=20
# Fallback: если за FALLBACK_MAX_AGE_DAYS дней не набралось MIN_BATCH,
# но накопилось хотя бы FALLBACK_MIN_BATCH — батч всё равно запускается,
# чтобы bio не застряло «навечно» (актуально для редкоговорящих аккаунтов).
TELEGRAM_CONTEXT_FALLBACK_MIN_BATCH=10
TELEGRAM_CONTEXT_FALLBACK_MAX_AGE_DAYS=7
# Сколько maybe/keep сообщений максимум попадает в prompt YandexGPT.
# Из них не более MAX_MAYBE_PROMPT_MESSAGES — это maybe (слабый сигнал);
# остаток заполняется keep (сильный сигнал). Лимит держит prompt в
# разумных токенах и не даёт maybe «затопить» сильные сигналы.
TELEGRAM_CONTEXT_MAX_PROMPT_MESSAGES=20
TELEGRAM_CONTEXT_MAX_MAYBE_PROMPT_MESSAGES=5

# ─── telegram_context: данные и отчёты ─────────────────────────────────────────
# Parquet-таблица с собранными сообщениями, их фичами и лейблами. Это
# источник правды для классификатора; SQLite используется только как
# быстрый индекс по message_key.
TELEGRAM_CONTEXT_DATASET=data/telegram_context.parquet
# Сюда складываются полные дампы каждого вызова YandexGPT (prompt + ответ).
# Удобно для отладки промпта и аудита генераций.
TELEGRAM_CONTEXT_REPORT_DIR=logs/context_api_reports

# ─── telegram_context: модели ──────────────────────────────────────────────────
# Каталог с весами mix0035 (stage1_catboost.cbm, stage2_nearest_centroid.pkl).
# Веса закоммичены в репозитории — на чистом клоне работает «из коробки».
TELEGRAM_CONTEXT_MODEL_DIR=data/prod_models/mix0035
# Stage-1 трансформер: быстрый, отсекает очевидный мусор (drop) до тяжёлой
# stage-2. Скачивается с HuggingFace при первом старте.
TELEGRAM_CONTEXT_STAGE1_MODEL=cointegrated/rubert-tiny2
# Stage-2 трансформер: более «семантичный» эмбеддинг, по нему CatBoost-голова
# различает maybe/keep.
TELEGRAM_CONTEXT_STAGE2_MODEL=sentence-transformers/distiluse-base-multilingual-cased-v2
# Доп. эмбеддинг-модель для скоринга «релевантности» (используется как
# числовая фича в классификаторе).
TELEGRAM_CONTEXT_FEATURE_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ─── telegram_context: NLI (опционально) ───────────────────────────────────────
# Включает дополнительный NLI-score как фичу. Заметно медленнее (ещё один
# transformer download + inference), на качество влияет умеренно — поэтому
# по умолчанию выключено.
TELEGRAM_CONTEXT_ENABLE_NLI_SCORE=false
TELEGRAM_CONTEXT_NLI_MODEL=cointegrated/rubert-base-cased-nli-threeway
