# ─── Telegram credentials ───────────────────────────────
# Get yours at https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Optional: Bot token for management bot (get from @BotFather)
# Leave empty to disable bot management
BOT_TOKEN=123

# ─── Bio provider ───────────────────────────────────────
# "list"         — pick from data/phrases.json (sequential)
# "llm"          — generate via LLM API (not yet implemented)
# "context_prod" — collect outgoing messages, classify them, generate bio by context
BIO_PROVIDER=list

# ─── Schedule ───────────────────────────────────────────
# How often to change bios (in minutes)
UPDATE_INTERVAL_MINUTES=60

# ─── YandexGPT (required when BIO_PROVIDER=llm) ────────
# API key from https://console.yandex.cloud/
YANDEX_API_KEY=your_yandex_api_key_here
# Folder ID from Yandex Cloud console
YANDEX_FOLDER_ID=your_folder_id_here
# Model: yandexgpt-lite/latest, yandexgpt/latest, etc.
YANDEX_MODEL=yandexgpt-lite/latest
# Temperature 0.0–1.0 (higher = more creative)
YANDEX_TEMPERATURE=0.9

# ─── Paths ──────────────────────────────────────────────
# Telethon session file name (without .session extension)
SESSION_NAME=telebio
# JSON file with phrases (relative to project root)
PHRASES_FILE=data/phrases.json
# JSON file with few-shot examples for LLM
EXAMPLES_FILE=data/examples.json

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── YandexGPT for context_prod ─────────────────────────
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt/latest
YANDEX_TEMPERATURE=0.7

# ─── context_prod runtime ───────────────────────────────
# Poll Telegram for new outgoing messages every N minutes.
CONTEXT_PROD_POLL_MINUTES=60
# Re-read a recent overlap window; messages are deduplicated in SQLite.
CONTEXT_PROD_FETCH_DAYS=7
# Generate when this many maybe/keep messages are pending.
CONTEXT_PROD_MIN_BATCH=20
# Fallback generation if a smaller batch waits too long.
CONTEXT_PROD_FALLBACK_MIN_BATCH=10
CONTEXT_PROD_FALLBACK_MAX_AGE_DAYS=7
# Prompt uses the latest N pending maybe/keep messages.
CONTEXT_PROD_MAX_PROMPT_MESSAGES=20
# Prompt uses at most this many maybe messages; the rest is reserved for keep.
CONTEXT_PROD_MAX_MAYBE_PROMPT_MESSAGES=5
CONTEXT_PROD_DB=data/context_prod.sqlite3
CONTEXT_PROD_MODEL_DIR=data/prod_models/mix0035
CONTEXT_PROD_STAGE1_MODEL=cointegrated/rubert-tiny2
CONTEXT_PROD_STAGE2_MODEL=sentence-transformers/distiluse-base-multilingual-cased-v2
CONTEXT_PROD_FEATURE_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Keep false by default: NLI is slower and downloads another transformer model.
CONTEXT_PROD_ENABLE_NLI_SCORE=false
CONTEXT_PROD_NLI_MODEL=cointegrated/rubert-base-cased-nli-threeway
CONTEXT_PROD_DIALOG_SCAN_LIMIT=500
CONTEXT_PROD_PER_DIALOG_LIMIT=100
